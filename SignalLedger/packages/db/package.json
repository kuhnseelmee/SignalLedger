{
  "name": "@signalledger/db",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": "./src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "pg": "^8.16.0",
    "zod": "^3.25.67",
    "@signalledger/config": "workspace:*",
    "@signalledger/shared": "workspace:*",
    "@signalledger/auth": "workspace:*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.3"
  }
}
