{
  "name": "signalledger",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "db:migrate": "pnpm --filter @signalledger/db db:migrate",
    "db:seed": "pnpm --filter @signalledger/db db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
